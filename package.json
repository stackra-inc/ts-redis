{
  "name": "@stackra/ts-redis",
  "version": "1.1.9",
  "description": "Multi-connection Redis via Upstash HTTP \u2014 cache stores, pub/sub, DI integration, React hooks",
  "license": "MIT",
  "author": {
    "name": "Stackra L.L.C",
    "email": "dev@stackra.com",
    "url": "https://stackra.com"
  },
  "keywords": [
    "stackra",
    "typescript",
    "redis",
    "upstash",
    "cache",
    "pub-sub",
    "react-hooks"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.cache",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@stackra/contracts": "workspace:*",
    "@upstash/redis": "catalog:"
  },
  "peerDependencies": {
    "@heroui-pro/react": "catalog:heroui",
    "@stackra/ts-cache": "workspace:*",
    "@stackra/ts-container": "workspace:*",
    "@stackra/ts-logger": "workspace:*",
    "@stackra/ts-support": "workspace:*",
    "react": "catalog:react"
  },
  "peerDependenciesMeta": {
    "@stackra/ts-cache": {
      "optional": false
    },
    "@stackra/ts-container": {
      "optional": false
    },
    "@stackra/ts-support": {
      "optional": false
    },
    "@stackra/ts-logger": {
      "optional": false
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@heroui-pro/react": "catalog:heroui",
    "@stackra/testing": "workspace:*",
    "@stackra/ts-cache": "workspace:*",
    "@stackra/ts-container": "workspace:*",
    "@stackra/ts-logger": "workspace:*",
    "@stackra/ts-support": "workspace:*",
    "@stackra/typescript-config": "catalog:stackra",
    "jiti": "catalog:build",
    "react": "catalog:react",
    "vite": "catalog:build"
  }
}
